# ===================================================================
# IDE and OS artifacts
# ===================================================================

# IDEs
.idea/
.vscode/
*.iml
*.iws
*.ipr

# OS junk
.DS_Store
Thumbs.db

# Editor backups
*~
*.swp
*.swo

# ===================================================================
# Java / Maven
# ===================================================================

# Build output for any module (Java, Kotlin, Scala — anything that uses Maven/Gradle)
**/target/
*.class
*.jar
*.war
*.ear

# Maven runtime files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Maven Wrapper (keep the actual jar)
.mvn/timing.properties
!.mvn/wrapper/maven-wrapper.jar

# JVM crash logs
hs_err_pid*

# ===================================================================
# Go
# ===================================================================

# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries
*.test
*.out

# Go workspace files (uncomment if used)
# go.work
# go.work.sum

# ===================================================================
# Node.js / Vite / React (jelenoid-ui)
# ===================================================================

# Dependencies
jelenoid-ui/node_modules/
test-app/node_modules/

# Build output
jelenoid-ui/dist/
jelenoid-ui/.vite/

# npm / yarn / pnpm debug logs
jelenoid-ui/npm-debug.log*
jelenoid-ui/yarn-debug.log*
jelenoid-ui/yarn-error.log*
jelenoid-ui/pnpm-debug.log*

# ===================================================================
# Logs
# ===================================================================

*.log
logs/

# ===================================================================
# Local secrets and config
# ===================================================================

# Local environment overrides (do NOT commit)
.env
.env.local
.env.*.local

# Any secret-bearing files
secrets/
*.secret

# ===================================================================
# Tool caches
# ===================================================================

.eslintcache
.stylelintcache
.prettiercache
